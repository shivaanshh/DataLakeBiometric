{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@modules/*":  ["src/modules/*"],
      "@storage/*":  ["src/storage/*"],
      "@screens/*":  ["src/screens/*"],
      "@utils/*":    ["src/utils/*"]
    }
  },
  "include": ["src/**/*", "native/**/*"],
  "exclude": ["node_modules", "**/__tests__/*"]
}
