{
	"$schema": "https://nitro.margelo.com/nitro.schema.json",
	"cxxNamespace": ["sensitiveinfo"],
	"ios": {
		"iosModuleName": "SensitiveInfo"
	},
	"android": {
		"androidNamespace": ["sensitiveinfo"],
		"androidCxxLibName": "SensitiveInfo"
	},
	"autolinking": {
		"SensitiveInfo": {
			"ios": {
				"language": "swift",
				"implementationClassName": "HybridSensitiveInfo"
			},
			"android": {
				"language": "kotlin",
				"implementationClassName": "HybridSensitiveInfo"
			}
		}
	},
	"ignorePaths": ["**/node_modules"]
}
